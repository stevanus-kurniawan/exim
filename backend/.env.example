# Exim Operation System - Backend environment example
# Copy this file to .env and set values. Never commit .env or real secrets.

# Environment
NODE_ENV=development
PORT=3003
# Trust N proxy hops for req.ip / rate limiting when X-Forwarded-For is set (Docker + Next.js: use 1). Omit for local direct-to-API.
# TRUST_PROXY=1

# Database (use port 5433 when connecting from host to EOS Postgres in Docker)
DATABASE_URL=postgres://eos:eos_dev_password@localhost:5433/eos_db

# Authentication — JWT_ACCESS_SECRET required for access tokens (set strong value in production).
JWT_ACCESS_SECRET=your-access-secret-change-in-production
# Optional — not used by current code (refresh tokens are stored in DB). Safe to omit unless you add JWT refresh signing later.
# JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# --- Storage (local disk or Synology via mount; see root .env.example for Docker bind) ---
STORAGE_TYPE=local

# Base folder for uploads (filing paths are relative to this). Pick ONE approach.
#
# Option B (recommended for Synology): resolves to <ROOT>/<deployment>/<project>/ e.g. dev/EOS
STORAGE_SYNOLOGY_ROOT=/mnt/synology/eos
STORAGE_DEPLOYMENT=dev
STORAGE_PROJECT_SLUG=EOS

# Option A — local folder only (no NAS): comment out Option B above and uncomment:
# STORAGE_LOCAL_PATH=./uploads

# Option C — single explicit path (overrides B if set):
# STORAGE_LOCAL_PATH=/mnt/synology/eos/dev/EOS

# Optional: shared folder / S3 (when STORAGE_TYPE is set accordingly)
# STORAGE_SHARED_PATH=
# STORAGE_S3_BUCKET=
# STORAGE_S3_REGION=
# STORAGE_S3_ACCESS_KEY=
# STORAGE_S3_SECRET_KEY=

# Shipment import duties — PPN/PPH as percent of (total PO amount + BM), e.g. 11 = 11%
# Default PPN/PPH % when shipment `ppn_percentage` / `pph_percentage` are NULL
PPN_PERCENTAGE=11
PPH_PERCENTAGE=2.5

# Dashboard procurement report: IDR per 1 USD for displaying line totals (after qty × unit_price × PO currency_rate → IDR)
# DASHBOARD_IDR_PER_USD=16500

# Logging
LOG_LEVEL=info

# Set true when the API is served only over HTTPS so auth cookies use the Secure flag (required for HttpOnly cookies in production).
# COOKIE_SECURE=true

# --- Production-only: scheduled DB backup (see scripts/backup/README.md and docker-compose.backup.yml)
# EOS_BACKUP_ENABLED=true
# EOS_ENV=production

# CORS — comma-separated browser origins allowed to call the API with credentials.
# In development (NODE_ENV=development), you may omit this to allow any origin.
# In staging/production, set explicitly (required or the server will not start).
# CORS_ORIGINS=http://localhost:3002,http://127.0.0.1:3002,https://eos.example.com

# PO polling (SaaS integration: detect new Import POs every 5 minutes)
# PO_POLLING_ENABLED=false
# PO_POLLING_INTERVAL_MS=300000
# SAAS_PO_API_BASE_URL=

# Registration & email verification
# Allow any email domain when true (e.g. development); otherwise only ALLOWED_EMAIL_DOMAIN
ALLOW_ANY_EMAIL=true
ALLOWED_EMAIL_DOMAIN=energi-up.com
# Base URL of frontend for verification and reset links (e.g. http://localhost:3002)
FRONTEND_BASE_URL=http://localhost:3002

# SMTP (for verification and password reset emails; auth required for relay)
SMTP_HOST=mail.energi-up.com
SMTP_PORT=587
# Port 587: usually STARTTLS → use false. Port 465: implicit TLS → use true.
SMTP_SECURE=false
SMTP_USER=noreply.sys@energi-up.com
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@energi-up.com

# Seed (optional; only in development or when RUN_SEED=true)
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=your-secure-password
