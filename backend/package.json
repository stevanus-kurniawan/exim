{
  "name": "eos-backend",
  "version": "1.0.0",
  "description": "Exim Operation System - Backend API (Phase 1 Import)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/run-migrations.ts",
    "migrate:prod": "node dist/db/run-migrations.js",
    "migrate:create": "echo 'Migration create script to be implemented' && exit 0",
    "seed": "tsx src/db/seed.ts",
    "seed:prod": "node dist/db/seed.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@sentry/node": "^8.55.1",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.12.0",
    "uuid": "^9.0.1"
  },
  "overrides": {
    "tar": "^7.5.11"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0"
  }
}
