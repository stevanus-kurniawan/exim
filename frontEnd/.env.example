# Exim Operation System - Frontend environment example
# Copy this file to .env / .env.local and set values. Never commit real secrets.

# Browser calls same-origin /api/backend/* ; Next server proxies to BACKEND_INTERNAL_URL (recommended UAT/prod).
NEXT_PUBLIC_API_URL=/api/backend

# Server-only: URL of EOS backend reachable from THIS Next.js process (private IP, docker service name, etc.).
# No /api/v1 suffix. Used by app/api/backend proxy routes — not exposed to the browser.
# Split servers example:
# BACKEND_INTERNAL_URL=http://172.28.92.57:3003
# Single docker-compose (service name):
# BACKEND_INTERNAL_URL=http://backend:3003
BACKEND_INTERNAL_URL=http://localhost:3003

# Optional: base URL of this Next.js app for server-side fetch when using /api/backend proxy (default http://127.0.0.1:3000).
# INTERNAL_NEXT_ORIGIN=http://127.0.0.1:3000

# Local dev without proxy (browser talks to backend directly):
# NEXT_PUBLIC_API_URL=http://localhost:3003/api/v1
# (Leave BACKEND_INTERNAL_URL unset or unused.)

# Optional: override Next.js defaults
# NEXT_PUBLIC_APP_NAME=Exim Operation System
