# Exim Operation System - Frontend environment example
# Copy this file to .env.local and set values. Never commit .env.local or secrets.

# Backend API base URL (used in browser; must be reachable from client)
# With Docker: use backend service name or host URL where the app is accessed
NEXT_PUBLIC_API_URL=http://localhost:3003/api/v1

# Optional: override Next.js defaults
# NEXT_PUBLIC_APP_NAME=Exim Operation System
