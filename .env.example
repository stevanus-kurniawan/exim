# EOS Docker Compose — copy to .env and set values. Never commit .env.

# PostgreSQL (used by postgres and backend services)
POSTGRES_USER=eos
POSTGRES_PASSWORD=eos_dev_password
POSTGRES_DB=eos_db
POSTGRES_PORT=5433

# Backend
BACKEND_PORT=3003
NODE_ENV=development

# Required for auth (set strong values in production)
JWT_ACCESS_SECRET=your-access-secret-change-in-production
# Optional — backend does not use this today (refresh tokens are DB-backed)
# JWT_REFRESH_SECRET=

# Optional: JWT expiry (defaults in backend)
# JWT_ACCESS_EXPIRES_IN=1h
# JWT_REFRESH_EXPIRES_IN=7d

# Frontend — browser uses same-origin /api/backend; Next proxies to BACKEND_INTERNAL_URL
FRONTEND_PORT=3002
NEXT_PUBLIC_API_URL=/api/backend
BACKEND_INTERNAL_URL=http://backend:3003

# Seed admin user (run: docker compose exec backend npm run seed)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123

# Optional: CORS (backend). Include both if you may open app via 127.0.0.1
# CORS_ORIGINS=http://localhost:3002,http://127.0.0.1:3002

# --- Storage: dev vs production (backend reads backend/.env; see backend/.env.example) ---
# Synology layout is dev/<project>/ or prod/<project>/ under the share (e.g. dev/EOS). STORAGE_LOCAL_PATH
# or STORAGE_SYNOLOGY_ROOT+DEPLOYMENT+PROJECT_SLUG in backend/.env must match the bind.
#
# docker compose.yml: optional bind mount instead of the default named volume (for local Synology testing)
# STORAGE_HOST_BIND=

# docker-compose.staging.backend.yml: host path bound to /mnt/synology/eos in the container
# STORAGE_HOST_MOUNT=/mnt/synology/eos
