# EOS split production deployment (copy to .env where you run compose)

# -------------------------------
# backend server (.backend stack)
# -------------------------------
POSTGRES_USER=eos
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=eos_db
POSTGRES_PORT=5432

BACKEND_PORT=3003
TRUST_PROXY=1
COOKIE_SECURE=true

# Set frontend origin(s) that are allowed to call backend with credentials.
# Example:
# CORS_ORIGINS=https://eos.example.com
CORS_ORIGINS=

# Synology host mount path on backend server.
STORAGE_HOST_MOUNT=/mnt/synology/eos

# -------------------------------
# frontend server (.frontend stack)
# -------------------------------
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=/api/backend

# Backend URL reachable from frontend container (no /api/v1 suffix).
# Example:
# BACKEND_INTERNAL_URL=http://10.10.10.20:3003
BACKEND_INTERNAL_URL=
